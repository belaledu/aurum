# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# GOOGLE_SPREADSHEET_ID: The ID of the Google Sheet acting as the database.
GOOGLE_SPREADSHEET_ID=""

# GOOGLE_CREDENTIALS: JSON string of the service account credentials.
GOOGLE_CREDENTIALS='{}'

# GOOGLE_DRIVE_ROOT_FOLDER_ID: The root folder ID for image uploads.
GOOGLE_DRIVE_ROOT_FOLDER_ID=""

# JWT_SECRET: Secret for signing JWT tokens.
JWT_SECRET="super-secret-jwt-key"

# VAT_RATE: Saudi VAT rate (default 0.15)
VAT_RATE=0.15
